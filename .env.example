# Copy to .env and fill in. `.env` is gitignored — never commit real secrets.
#   cp .env.example .env
# Loaded by load_dotenv() in .claude/src/explore_lit.py before `prior` is imported.

# --- LLM backend ---------------------------------------------------------------
# "claude-code" routes through the Claude Agent SDK and uses your local Claude
# Code login — NO ANTHROPIC_API_KEY needed. You must be logged in to Claude Code
# on this machine, and `prior[claude-code]` must be installed (see requirements).
PRIOR_LLM_BACKEND=claude-code

# If you switch to the "api" backend instead, comment the line above and set:
# PRIOR_LLM_BACKEND=api
# ANTHROPIC_API_KEY=sk-ant-...

# --- Required for polite, reliable source access -------------------------------
# Sent to OpenAlex / Unpaywall "polite pool" for faster, more reliable access.
PRIOR_CONTACT_EMAIL=your_academic_email

# --- Where the scoped corpus is cached -----------------------------------------
# Relative to wherever you run from. Created automatically.
PRIOR_DATA_DIR=.cache

# --- Optional ------------------------------------------------------------------
# Higher Semantic Scholar rate limits (request a key from semanticscholar.org):
# PRIOR_S2_API_KEY=...
